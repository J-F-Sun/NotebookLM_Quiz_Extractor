{
  "manifest_version": 3,
  "name": "NotebookLM Quiz Extractor",
  "version": "0.1.0",
  "description": "Export multiple-choice quizzes from NotebookLM app/blob frames.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["downloads"],
  "host_permissions": [
    "https://notebooklm.google.com/*",
    "https://*.notebooklm.google.com/*",
    "https://*.usercontent.goog/*",
    "https://*.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/*",
        "https://*.notebooklm.google.com/*",
        "https://*.usercontent.goog/*",
        "https://*.googleusercontent.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_title": "NotebookLM Quiz Extractor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
